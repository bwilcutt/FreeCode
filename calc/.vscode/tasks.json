{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "/media/Share/Calc/parse.c",
                "/media/Share/Calc/matrix.c",
		"/media/Share/Calc/reynolds.c",
		"/media/Share/Calc/mannings.c",
		"/media/Share/Calc/darcy.c",
		"/media/Share/Calc/bernoulli.c",
		"/media/Share/Calc/mohr.c",
		"/media/Share/Calc/specheat.c",
		"/media/Share/Calc/beam.c",
		"/media/Share/Calc/orifice.c",
		"/media/Share/Calc/stress.c",
		"/media/Share/Calc/idealgas.c",
		"/media/Share/Calc/conduct.c",
		"/media/Share/Calc/pid.c",
                "-o",
                "/media/Share/Calc/parse",
                "-lm"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "test",
            "type": "shell",
            "command": "grep -v '^#' /media/Share/Calc/test_commands.txt | /media/Share/Calc/parse | grep -n '^0$' && echo 'FAILURES FOUND' || echo 'All tests passed'",
            "dependsOn": "build",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
