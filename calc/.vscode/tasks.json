{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "parse.c",
                "csv.c",
                "Algo/matrix.c",
                "Algo/reynolds.c",
                "Algo/mannings.c",
                "Algo/darcy.c",
                "Algo/bernoulli.c",
                "Algo/mohr.c",
                "Algo/specheat.c",
                "Algo/beam.c",
                "Algo/orifice.c",
                "Algo/stress.c",
                "Algo/idealgas.c",
                "Algo/conduct.c",
                "Algo/pid.c",
                "Algo/fft.c",
                "-I", ".",
                "-I", "Algo",
                "-I", "PipeMgr",
                "-o", "parse",
                "-lm"
            ],
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "pipe_test",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "PipeMgr/pipe_test.c",
                "PipeMgr/pipe_mgr.c",
                "-I", ".",
                "-I", "Algo",
                "-I", "PipeMgr",
                "-o", "pipe_test",
                "-lm",
                "&&", "./pipe_test", "./parse"
            ],
            "dependsOn": "build",
            "problemMatcher": ["$gcc"],
            "group": "test"
        },
        {
            "label": "test",
            "type": "shell",
            "command": "cd TestData && ./test_suite.sh",
            "dependsOn": "build",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
